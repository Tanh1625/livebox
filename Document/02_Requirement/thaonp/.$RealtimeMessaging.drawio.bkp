        <mxCell id="c_e8" source="show_retry" target="f_reconnect" edge="1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="c_e9" source="f_reconnect" target="e_c" edge="1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>